{
    "name": "ngcp-admin-ui",
    "version": "0.0.1",
    "description": "User interface to administer the NGCP platform",
    "productName": "NGCP Admin UI",
    "cordovaId": "com.sipwise.ui.admin",
    "capacitorId": "",
    "author": "Hans-Peter Herzog <hherzog@sipwise.com>",
    "private": true,
    "scripts": {
        "lint": "eslint .",
        "test": "yarnpkg test:unit",
        "quasar": "quasar",
        "build": "quasar build",
        "config": "bash bin/dev-config-create.sh",
        "dev": "quasar dev",
        "upgrade": "quasar upgrade",
        "upgrade:conduct": "quasar upgrade -i",
        "docker:kill": "bash bin/docker-kill.sh",
        "docker:pull": "docker pull docker.mgm.sipwise.com/ngcp-admin-ui-buster:latest",
        "docker:run": "docker run --name=ngcp-admin-ui --rm -p 8080:8080 -i -t -v $(pwd):/code:rw docker.mgm.sipwise.com/ngcp-admin-ui-buster:latest t/run_admin_ui $1",
        "dev:docker": "yarnpkg run docker:kill && yarnpkg run docker:pull && yarnpkg run docker:run",
        "new:store": "quasar new store $1",
        "new:page": "quasar new page $1",
        "i18n:import": "node ./bin/i18n-import.js",
        "i18n:extract": "bash bin/vue-i18n-extract/extract.sh",
        "i18n:extract-report": "bash bin/vue-i18n-extract/extract.sh report",
        "test:unit": "jest --updateSnapshot",
        "test:unit:ci": "jest --ci",
        "test:unit:coverage": "jest --coverage",
        "test:unit:watch": "jest --watch",
        "test:unit:watchAll": "jest --watchAll",
        "serve:test:coverage": "quasar serve test/jest/coverage/lcov-report/ --port 8788",
        "concurrently:dev:jest": "concurrently \"quasar dev\" \"jest --watch\""
    },
    "dependencies": {
        "@daypilot/daypilot-lite-vue": "5.9.0",
        "@quasar/extras": "1.18.0",
        "@vuelidate/core": "2.0.3",
        "@vuelidate/validators": "2.0.4",
        "axios": "1.18.1",
        "buffer": "6.0.3",
        "chart.js": "4.5.1",
        "content-disposition": "^1.0.1",
        "core-js": "3.49.0",
        "crypto-browserify": "3.12.1",
        "crypto-js": "4.2.0",
        "decode-uri-component": "^0.5.0",
        "diff": "9.0.0",
        "eslint-plugin-no-relative-import-paths": "1.6.1",
        "eslint-plugin-unused-imports": "4.4.1",
        "express": "^5.2.1",
        "globals": "17.7.0",
        "jest-junit": "17.0.0",
        "loader-utils": "^3.2.1",
        "moment": "^2.29.4",
        "path": "0.12.7",
        "prismjs": "1.30.0",
        "process": "0.11.10",
        "quasar": "2.21.2",
        "stream-browserify": "3.0.0",
        "terser": "^5.49.0",
        "validator": "13.15.35",
        "vis-timeline": "8.5.1",
        "vue": "3.5.39",
        "vue-chartjs": "5.3.4",
        "vue-i18n": "11.4.6",
        "vue-json-pretty": "2.6.0",
        "vue-router": "4.5.1",
        "vue-simple-password-meter": "1.4.0",
        "vue-word-highlighter": "1.2.6",
        "vuex": "4.1.0"
    },
    "devDependencies": {
        "@babel/eslint-parser": "^8.0.1",
        "@quasar/app-webpack": "4.4.5",
        "@quasar/cli": "5.0.2",
        "@quasar/quasar-app-extension-testing": "2.2.0",
        "@quasar/quasar-app-extension-testing-unit-jest": "3.0.3",
        "@stylistic/eslint-plugin-js": "4.4.1",
        "@vue/test-utils": "2.4.11",
        "autoprefixer": "10.5.2",
        "commander": "15.0.0",
        "decomment": "0.9.5",
        "dot-object": "2.1.5",
        "eslint": "9.39.5",
        "eslint-config-standard": "17.1.0",
        "eslint-plugin-import": "2.32.0",
        "eslint-plugin-jest": "29.15.4",
        "eslint-plugin-n": "18.2.1",
        "eslint-plugin-node": "11.1.0",
        "eslint-plugin-promise": "7.3.0",
        "eslint-plugin-quasar": "1.1.0",
        "eslint-plugin-standard": "5.0.0",
        "eslint-plugin-vue": "^10.9.2",
        "eslint-webpack-plugin": "6.0.0",
        "file-saver": "^2.0.2",
        "glob": "13.0.6",
        "imports-loader": "5.0.0",
        "is-cidr": "7.0.0",
        "is-valid-glob": "1.0.0",
        "jest": "30.3.0",
        "jest-serializer-vue": "3.1.0",
        "js-yaml": "5.2.1",
        "json-beautify": "1.1.1",
        "jwt-decode": "4.0.0",
        "lodash": "4.18.1",
        "moment-locales-webpack-plugin": "1.2.0",
        "path-browserify": "1.0.1",
        "po2json": "1.0.0-beta-3",
        "portal-vue": "^3.0.0",
        "prettier": "3.9.5",
        "qs": "^6.14.1",
        "vue-eslint-parser": "^10.4.1",
        "vue-wait": "^1.5.3",
        "vuelidate": "^0.7.7",
        "zxcvbn": "^4.4.2"
    },
    "engines": {
        "node": ">=24.14.0 < 25",
        "yarn": ">=4.17.1"
    },
    "resolutions": {
        "form-data": "^4.0.6",
        "qs": "^6.15.2"
    },
    "browserslist": [
        "last 1 version, not dead, ie >= 11"
    ],
    "packageManager": "yarn@4.17.1"
}
